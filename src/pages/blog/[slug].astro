                    c-2.362-1.145-3.865-3.556-3.749-5.979c0.08-1.639,0.886-2.891,2.011-4.014c5.441-5.433,10.867-10.88,16.295-16.322
                    C42.183,68.197,42.518,67.813,43.041,67.254z"/>
                  <path d="M47.55,48.329c-13.205-0.045-24.033-10.992-23.956-24.218C23.67,10.739,34.505-0.037,47.84,0
                    c13.362,0.036,24.087,10.967,24.02,24.478C71.792,37.677,60.889,48.375,47.55,48.329z M59.551,24.143
                    c-0.023-6.567-5.253-11.795-11.807-11.801c-6.609-0.007-11.886,5.316-11.835,11.943c0.049,6.542,5.324,11.733,11.896,11.709
                    C54.357,35.971,59.573,30.709,59.551,24.143z"/>
                </g>
              </g>
            </svg>
            <span>OK.ru</span>
          </a>
          
          <!-- Max -->
          <!-- <a href={shareLinks.max} target="_blank" rel="noopener noreferrer"
             class="share-btn share-btn--max" aria-label="Поделиться в Макс">
             <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" xml:space="preserve" viewBox="0 0 1000 1000">
              <defs>
              <linearGradient id="b">
              <stop offset="0" stop-color="#00f"/>
              <stop offset="1" stop-opacity="0"/>
              <stop offset="1" stop-opacity="0"/>
              </linearGradient>
              <linearGradient id="a">
              <stop offset="0" stop-color="#4cf"/>
              <stop offset=".662" stop-color="#53e"/>
              <stop offset="1" stop-color="#93d"/>
              </linearGradient>
              <linearGradient id="c" x1="117.847" x2="1000" y1="760.536" y2="500" gradientUnits="userSpaceOnUse" href="#a"/>
              <radialGradient id="d" cx="-87.392" cy="1166.116" r="500" fx="-87.392" fy="1166.116" gradientTransform="rotate(51.356 1551.478 559.3)scale(2.42703433 1)" gradientUnits="userSpaceOnUse" href="#b"/>
              </defs>
              <rect width="1000" height="1000" fill="url(#c)" ry="249.681"/>
              <rect width="1000" height="1000" fill="url(#d)" ry="249.681"/>
              <path fill="#fff" fill-rule="evenodd" d="M508.211 878.328c-75.007 0-109.864-10.95-170.453-54.75-38.325 49.275-159.686 87.783-164.979 21.9 0-49.456-10.95-91.248-23.36-136.873-14.782-56.21-31.572-118.807-31.572-209.508 0-216.626 177.754-379.597 388.357-379.597 210.785 0 375.947 171.001 375.947 381.604.707 207.346-166.595 376.118-373.94 377.224m3.103-571.585c-102.564-5.292-182.499 65.7-200.201 177.024-14.6 92.162 11.315 204.398 33.397 210.238 10.585 2.555 37.23-18.98 53.837-35.587a189.8 189.8 0 0 0 92.71 33.032c106.273 5.112 197.08-75.794 204.215-181.95 4.154-106.382-77.67-196.486-183.958-202.574Z" clip-rule="evenodd"/>
            </svg>
            <span>Макс</span>
          </a> -->

          <!-- Яндекс Дзен -->
          <a href={shareLinks.dzen} target="_blank" rel="noopener noreferrer"
             class="share-btn share-btn--dzen" aria-label="Поделиться в Яндекс Дзен">
             <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 28 28">
              <path fill="#2C3036"
                  d="M16.7 16.7c-2.2 2.27-2.36 5.1-2.55 11.3 5.78 0 9.77-.02 11.83-2.02 2-2.06 2.02-6.24 2.02-11.83-6.2.2-9.03.35-11.3 2.55M0 14.15c0 5.59.02 9.77 2.02 11.83 2.06 2 6.05 2.02 11.83 2.02-.2-6.2-.35-9.03-2.55-11.3-2.27-2.2-5.1-2.36-11.3-2.55M13.85 0C8.08 0 4.08.02 2.02 2.02.02 4.08 0 8.26 0 13.85c6.2-.2 9.03-.35 11.3-2.55 2.2-2.27 2.36-5.1 2.55-11.3m2.85 11.3C14.5 9.03 14.34 6.2 14.15 0c5.78 0 9.77.02 11.83 2.02 2 2.06 2.02 6.24 2.02 11.83-6.2-.2-9.03-.35-11.3-2.55">
              </path>
              <path fill="#fff"
                  d="M28 14.15v-.3c-6.2-.2-9.03-.35-11.3-2.55-2.2-2.27-2.36-5.1-2.55-11.3h-.3c-.2 6.2-.35 9.03-2.55 11.3-2.27 2.2-5.1 2.36-11.3 2.55v.3c6.2.2 9.03.35 11.3 2.55 2.2 2.27 2.36 5.1 2.55 11.3h.3c.2-6.2.35-9.03 2.55-11.3 2.27-2.2 5.1-2.36 11.3-2.55">
              </path>
            </svg>
            <span>Дзен</span>
          </a>

        </div>
      </div>
    </div>
  </section>

  <!-- Related posts -->
  {related.length > 0 && (
    <section class="related-section section">
      <div class="container">
        <AnimatedBlock>
          <h2 class="related-title">Также вам может быть интересно</h2>
        </AnimatedBlock>
        <div class="related-grid">
          {related.map((rPost, i) => (
            <AnimatedBlock animation="fade-up" delay={i * 80}>
              <article class="related-card">
                <a href={`/blog/${rPost.slug}/`} class="related-card-img-link" tabindex="-1">
                  <img
                    src={rPost.data.coverImage}
                    alt={rPost.data.title}
                    class="related-card-img"
                    loading="lazy"
                    width="400"
                    height="260"
                  />
                </a>
                <div class="related-card-body">
                  <h3 class="related-card-title">
                    <a href={`/blog/${rPost.slug}/`}>{rPost.data.title}</a>
                  </h3>
                  <time class="blog-card-date" datetime={rPost.data.date.toISOString()}>
                    {formatDate(rPost.data.date)}
                  </time>
                  <a href={`/blog/${post.slug}/`} class="related-card-read">Читать далее →</a>
                </div>
              </article>
            </AnimatedBlock>
          ))}
        </div>
      </div>
    </section>
  )}

  <script define:vars={{ blogSlug: post.slug }}>
    (function () {
      const countEl = document.getElementById('article-views-count');
      if (!countEl) return;
      const fmt = new Intl.NumberFormat('ru-RU');
      const storageKey = 'tpc:blog-view:' + blogSlug;

      let alreadyCounted = false;
      try {
        alreadyCounted = sessionStorage.getItem(storageKey) === '1';
      } catch {
        /* приватный режим / запрет storage — считаем как новый визит */
      }

      function applyViews(data) {
        const n = typeof data.views === 'number' ? data.views : 0;
        countEl.textContent = fmt.format(n);
      }

      const req = alreadyCounted
        ? fetch('/api/blog-views?slug=' + encodeURIComponent(blogSlug))
        : fetch('/api/blog-views', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ slug: blogSlug }),
          }).then(function (res) {
            if (!res.ok) return Promise.reject();
            return res.json().then(function (data) {
              try {
                sessionStorage.setItem(storageKey, '1');
              } catch {
                /* не помечаем — при обновлении снова будет POST */
              }
              return data;
            });
          });

      req
        .then(function (res) {
          if (alreadyCounted) {
            return res.ok ? res.json() : Promise.reject();
          }
          return res;
        })
        .then(applyViews)
        .catch(function () {
          countEl.textContent = '—';
        });
    })();
  </script>

</BaseLayout>

<style>
  /* ── Hero ───────────────────────────────────────────── */
  .article-hero {
    background:  var(--color-fog);
    padding:     var(--spacing-48) 0 var(--spacing-40);
  }

  .article-tags {
    display:       flex;
    flex-wrap:     wrap;
    gap:           var(--spacing-10);
    margin-bottom: var(--spacing-16);
  }

  .blog-tag {
    font-family:    var(--font-sohne);
    font-size:      11px;
    font-weight:    500;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color:          var(--color-terracotta);
    background:     rgba(180, 80, 50, 0.08);
    padding:        3px 10px;
    border-radius:  100px;
  }

  .article-title {
    font-family:   var(--font-signifier);
    font-size:     clamp(28px, 5vw, 48px);
    font-weight:   400;
    line-height:   1.2;
    color:         var(--color-ink);
    max-width:     800px;
    margin-bottom: var(--spacing-20);
  }

  .article-hero-inner {
    padding-bottom: var(--spacing-20);
  }

  .article-meta {
    display:     flex;
    align-items: center;
    gap:         var(--spacing-16);
    flex-wrap:   wrap;
  }

  .article-date,
  .article-author {
    font-family: var(--font-sohne);
    font-size:   14px;
    color:       var(--color-muted-stone);
  }

  .article-author::before {
    content: '·';
    margin-right: var(--spacing-16);
    opacity: .4;
  }

  /* ── Cover ──────────────────────────────────────────── */
  .article-cover-wrap {
    background: var(--color-fog);
    padding-bottom: var(--spacing-40);
  }

  .article-cover {
    width:         100%;
    max-height:    480px;
    object-fit:    cover;
    border-radius: var(--radius-cards);
    display:       block;
  }

  /* ── Prose content ──────────────────────────────────── */
  .article-body { background: var(--color-canvas); }

  .article-content {
    max-width: 1200px;
  }

  .article-views {
    display:         flex;
    align-items:     center;
    gap:             var(--spacing-10);
    margin:          var(--spacing-32) 0 0;
    padding-top:     var(--spacing-24);
    border-top:      1px solid rgba(0, 0, 0, 0.08);
    font-family:     var(--font-sohne);
    font-size:       14px;
    font-weight:     500;
    color:           var(--color-muted-stone);
  }

  .article-views-icon {
    flex-shrink: 0;
    opacity: 0.85;
  }

  .article-views-count {
    font-variant-numeric: tabular-nums;
    letter-spacing:       0.02em;
    color:                var(--color-ink);
  }

  .prose :global(li) {
    list-style: initial;
  }

  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: var(--spacing-20);
  }

  .prose :global(th) {
    background-color: var(--color-fog);
  }

  .prose :global(td) {
    padding: var(--spacing-10);
    border: 1px solid var(--color-fog);
  }

  .prose :global(h2) {
    font-family:   var(--font-signifier);
    font-size:     clamp(22px, 3vw, 28px);
    font-weight:   400;
    color:         var(--color-ink);
    margin-top:    var(--spacing-48);
    margin-bottom: var(--spacing-16);
    line-height:   1.3;
  }

  .prose :global(h3) {
    font-family:   var(--font-sohne);
    font-size:     18px;
    font-weight:   500;
    color:         var(--color-ink);
    margin-top:    var(--spacing-32);
    margin-bottom: var(--spacing-12);
  }

  .prose :global(p) {
    font-family:   var(--font-sohne);
    font-size:     16px;
    line-height:   1.75;
    color:         var(--color-ink);
    margin-bottom: var(--spacing-20);
  }

  .prose :global(ul),
  .prose :global(ol) {
    font-family:   var(--font-sohne);
    font-size:     16px;
    line-height:   1.75;
    color:         var(--color-ink);
    padding-left:  var(--spacing-24);
    margin-bottom: var(--spacing-20);
  }

  .prose :global(li) {
    margin-bottom: var(--spacing-8);
  }

  .prose :global(strong) {
    font-weight: 600;
    color:       var(--color-ink);
  }

  .prose :global(img) {
    width:         100%;
    max-width:  480px;
    margin-bottom: var(--spacing-32);
    border-radius: var(--radius-cards);
    display:       block;
    float: right;
    margin-left: var(--spacing-32);
  }

  .prose :global(hr) {
    border:        none;
    border-top:    1px solid rgba(0,0,0,.1);
    margin:        var(--spacing-40) 0;
  }

  .prose :global(a) {
    color:                var(--color-ink);
    text-decoration:      underline;
    text-decoration-color: rgba(0,0,0,.3);
    text-underline-offset: 2px;
  }
  .prose :global(a:hover) { text-decoration-color: var(--color-ink); }

  /* ── Share ──────────────────────────────────────────── */
  .article-share-section {
    background:  var(--color-fog);
    padding:     var(--spacing-32) 0;
    border-top:  1px solid rgba(0,0,0,.07);
  }

  .article-share {
    display:     flex;
    align-items: center;
    gap:         var(--spacing-20);
    flex-wrap:   wrap;
  }

  .share-label {
    font-family:  var(--font-sohne);
    font-size:    14px;
    font-weight:  500;
    color:        var(--color-muted-stone);
    white-space:  nowrap;
    margin:       0;
  }

  .share-btns {
    display:   flex;
    flex-wrap: wrap;
    gap:       var(--spacing-8);
  }

  .share-btn {
    display:         inline-flex;
    align-items:     center;
    gap:             var(--spacing-8);
    padding:         9px 16px;
    border-radius:   100px;
    font-family:     var(--font-sohne);
    font-size:       14px;
    font-weight:     500;
    text-decoration: none;
    transition:      opacity 0.15s, transform 0.15s;
    color:           #fff;
    white-space:     nowrap;
  }
  .share-btn:hover { opacity: .88; transform: translateY(-1px); }

  .share-btn--tg   { background: #2AABEE; }
  .share-btn--vk   { background: #0077FF; }
  .share-btn--ok   { background: #f7931e; }
  .share-btn--dzen { background: #FF0000; }
  .share-btn--max  { background: #9a27ff; }

  /* ── Related ────────────────────────────────────────── */
  .related-section { background: var(--color-canvas); }

  .related-title {
    font-family:   var(--font-signifier);
    font-size:     clamp(22px, 3vw, 28px);
    font-weight:   400;
    color:         var(--color-ink);
    margin-bottom: var(--spacing-32);
  }

  .related-grid {
    display:               grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap:                   var(--spacing-24);
  }

  .related-card {
    border:        1px solid rgba(0,0,0,.07);
    border-radius: var(--radius-cards);
    overflow:      hidden;
    background:    var(--color-canvas);
