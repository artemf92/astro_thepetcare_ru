---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import AnimatedBlock from '../../components/ui/AnimatedBlock.astro';
import Breadcrumb from '../../components/ui/Breadcrumb.astro';
import { site } from '../../data/site';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({ params: { slug: post.slug }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await post.render();

// Связанные статьи: все остальные, новые первые, максимум 4
const allPosts = await getCollection('blog');
const related = allPosts
  .filter(p => p.slug !== post.slug)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 4);

function formatDate(date: Date): string {
  return date.toLocaleDateString('ru-RU', { day: 'numeric', month: 'long', year: 'numeric' });
}

const pageUrl    = `${site.url}/blog/${post.slug}/`;
const pageTitle  = encodeURIComponent(post.data.title);
const pageUrlEnc = encodeURIComponent(pageUrl);

const shareLinks = {
  telegram: `https://t.me/share/url?url=${pageUrlEnc}&text=${pageTitle}`,
  vk:       `https://vk.com/share.php?url=${pageUrlEnc}&title=${pageTitle}`,
  max:      `https://connect.ok.ru/offer?url=${pageUrlEnc}&title=${pageTitle}`,
  dzen:     `https://dzen.ru/share/?url=${pageUrlEnc}&title=${pageTitle}`,
};
---

<BaseLayout
  title={`${post.data.title} | Блог The Pet Care`}
  description={post.data.excerpt}
  ogImage={post.data.coverImage}
  noindex={true}
>

  <Breadcrumb items={[{ label: 'Блог', href: '/blog/' }, { label: post.data.title }]} />

  <!-- Hero -->
  <section class="article-hero">
    <div class="container">
      <div class="article-hero-inner">
        <AnimatedBlock>
          {post.data.tags.length > 0 && (
            <div class="article-tags">
              {post.data.tags.map(tag => <span class="blog-tag">{tag}</span>)}
            </div>
          )}
          <h1 class="article-title">{post.data.title}</h1>
          <div class="article-meta">
            <time datetime={post.data.date.toISOString()} class="article-date">
              {formatDate(post.data.date)}
            </time>
            <!-- <span class="article-author">{post.data.author}</span> -->
          </div>
        </AnimatedBlock>
      </div>
    </div>
  </section>

  <!-- Content -->
  <article class="article-body section">
    <div class="container">
      <div class="article-content prose">
        <Content />
      </div>
      <p class="article-views" id="article-views" role="status" aria-live="polite" title="Количество просмотров">
        <svg
          class="article-views-icon"
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"></path>
          <circle cx="12" cy="12" r="3"></circle>
        </svg>
        <span id="article-views-count" class="article-views-count">…</span>
      </p>
    </div>
  </article>

  <!-- Share -->
  <section class="article-share-section">
    <div class="container">
      <div class="article-share">
        <p class="share-label">Поделиться:</p>
        <div class="share-btns">

          <!-- Telegram -->
          <a href={shareLinks.telegram} target="_blank" rel="noopener noreferrer"
             class="share-btn share-btn--tg" aria-label="Поделиться в Telegram">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm5.894 8.221-1.97 9.28c-.145.658-.537.818-1.084.508l-3-2.21-1.447 1.394c-.16.16-.295.295-.605.295l.213-3.053 5.56-5.023c.242-.213-.054-.333-.373-.12l-6.871 4.326-2.962-.924c-.643-.204-.657-.643.136-.953l11.57-4.461c.537-.194 1.006.131.833.941z"/>
            </svg>
            <span>Telegram</span>
          </a>

          <!-- VK -->
          <a href={shareLinks.vk} target="_blank" rel="noopener noreferrer"
             class="share-btn share-btn--vk" aria-label="Поделиться ВКонтакте">
             <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 24 24"><path class="st0" d="M13.162 18.994c.609 0 .858-.406.851-.915-.031-1.917.714-2.949 2.059-1.604 1.488 1.488 1.796 2.519 3.603 2.519h3.2c.808 0 1.126-.26 1.126-.668 0-.863-1.421-2.386-2.625-3.504-1.686-1.565-1.765-1.602-.313-3.486 1.801-2.339 4.157-5.336 2.073-5.336h-3.981c-.772 0-.828.435-1.103 1.083-.995 2.347-2.886 5.387-3.604 4.922-.751-.485-.407-2.406-.35-5.261.015-.754.011-1.271-1.141-1.539-.629-.145-1.241-.205-1.809-.205-2.273 0-3.841.953-2.95 1.119 1.571.293 1.42 3.692 1.054 5.16-.638 2.556-3.036-2.024-4.035-4.305-.241-.548-.315-.974-1.175-.974h-3.255c-.492 0-.787.16-.787.516 0 .602 2.96 6.72 5.786 9.77 2.756 2.975 5.48 2.708 7.376 2.708z"/></svg>
            <span>ВКонтакте</span>
          </a>

          <!-- OK.ru -->
          <a href={shareLinks.max} target="_blank" rel="noopener noreferrer"
             class="share-btn share-btn--ok" aria-label="Поделиться в Одноклассники">
             <svg version="1.1" id="Capa_1" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" x="0px" y="0px"
             width="20" height="20" fill="currentColor" viewBox="0 0 95.481 95.481" style="enable-background:new 0 0 95.481 95.481;"
             xml:space="preserve">
              <g>
                <g>
                  <path d="M43.041,67.254c-7.402-0.772-14.076-2.595-19.79-7.064c-0.709-0.556-1.441-1.092-2.088-1.713
                    c-2.501-2.402-2.753-5.153-0.774-7.988c1.693-2.426,4.535-3.075,7.489-1.682c0.572,0.27,1.117,0.607,1.639,0.969
                    c10.649,7.317,25.278,7.519,35.967,0.329c1.059-0.812,2.191-1.474,3.503-1.812c2.551-0.655,4.93,0.282,6.299,2.514
                    c1.564,2.549,1.544,5.037-0.383,7.016c-2.956,3.034-6.511,5.229-10.461,6.761c-3.735,1.448-7.826,2.177-11.875,2.661
                    c0.611,0.665,0.899,0.992,1.281,1.376c5.498,5.524,11.02,11.025,16.5,16.566c1.867,1.888,2.257,4.229,1.229,6.425
                    c-1.124,2.4-3.64,3.979-6.107,3.81c-1.563-0.108-2.782-0.886-3.865-1.977c-4.149-4.175-8.376-8.273-12.441-12.527
