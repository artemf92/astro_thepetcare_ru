---
import BaseLayout from '../layouts/BaseLayout.astro';
import AnimatedBlock from '../components/ui/AnimatedBlock.astro';
import { site } from '../data/site';
import { serviceCategories } from '../data/services-list';
import { Image } from 'astro:assets';

const dogServices = serviceCategories.find(c => c.category === 'Для собак')?.items ?? [];
const catServices = serviceCategories.find(c => c.category === 'Для кошек')?.items ?? [];

const getExperience = (expFrom: string) => {
  const currentYear = new Date().getFullYear();
  const expYears = currentYear - parseInt(expFrom);
  const expYearsText = getPluralForm(expYears, 'год', 'года', 'лет');

  if (expYears < 1) return 'Стаж менее года';
  return `Стаж ${expYears} ${expYearsText}`;
};

const getPluralForm = (count: number, one: string, few: string, many: string) => {
  if (count % 10 === 1 && count % 100 !== 11) return one;
  if (count % 10 === 2 && count % 100 !== 12) return few;
  if (count % 10 === 3 && count % 100 !== 13) return many;
  return many;
};

const masters = [
  { name: 'Карина',  role: 'Топ-мастер',            expFrom: '2019',       img: '/images/uploads/11266.webp' },
  { name: 'Анна',    role: 'Мастер',                expFrom: '2024',      img: '/images/uploads/11622.webp' },
  { name: 'Надежда', role: 'Младший мастер',        expFrom: '2026',  img: '/images/uploads/11623.webp' },
  { name: 'Юлия',    role: 'Помощник топ-мастера',  expFrom: '2026',  img: '/images/uploads/11624.webp' },
  { name: 'Даниил',  role: 'Младший мастер',        expFrom: '2026',  img: '/images/uploads/11625.webp' },
];

const gallery = [
  '/images/uploads/11247.webp', '/images/uploads/11248.webp', '/images/uploads/11249.webp',
  '/images/uploads/11250.webp', '/images/uploads/11252.webp', '/images/uploads/11253.webp',
  '/images/uploads/11254.webp', '/images/uploads/11255.webp', '/images/uploads/11256.webp',
];
---

<BaseLayout
  title="Груминг-салон в Калининграде | Стрижка собак и кошек | ThePetCare.ru"
  description="Груминг салон【The Pet Care】для собак и кошек в Калининграде. Стрижка, уход за собаками и кошками премиального качества! Услуги от мастеров с большим опытом работы. Профессиональная косметика. Обращайтесь ☎ +7 (902) 416-99-59"
>
  <!-- Preload LCP-изображения (hero background) — критично для Core Web Vitals -->
  <link
    rel="preload"
    href="/images/uploads/hero-bg.webp"
    as="image"
    type="image/webp"
    fetchpriority="high"
    slot="head"
  />

  <!-- ══════════════════════════════════════════
       HERO
  ══════════════════════════════════════════ -->
  <section class="hero">
    <div class="hero-bg" aria-hidden="true"></div>
    <div class="container hero-content">
      <AnimatedBlock animation="fade-up">
        {/* <p class="hero-eyebrow">Груминг-студия в Калининграде</p> */}
        <h1 class="hero-title">Груминг-салон <br>"Студия заботливого груминга"<br> в Калининграде</h1>
      </AnimatedBlock>
      <AnimatedBlock animation="fade-up" delay={120}>
        <p class="hero-sub">
          Груминг салон предоставляет премиум-уход для собак и кошек всех пород. <br>
          Следим за здоровьем и оказываем питомцам заботу и внимание. Запишитесь онлайн или позвоните.
        </p>
      </AnimatedBlock>
      <AnimatedBlock animation="fade-up" delay={220}>
        <div class="hero-actions">
          <a href={site.booking} class="btn btn-hero" target="_blank" rel="noopener noreferrer">
            Записаться
          </a>
          {/*<a href={`tel:${site.contacts.phoneRaw}`} class="btn btn-hero-ghost">
            {site.contacts.phone}
          </a> */}
        </div>
      </AnimatedBlock>
      {/*<AnimatedBlock animation="fade-up" delay={320}>
        <p class="hero-address">📍 {site.contacts.address}</p>
      </AnimatedBlock>*/}
    </div>
  </section>

  <!-- ══════════════════════════════════════════
       INTRO-БЛОК
  ══════════════════════════════════════════ -->
  <section class="intro-block">
    <div class="container">

      <div class="intro-grid">
  
        <!-- Фото -->
        <AnimatedBlock animation="fade-right" class="intro-img-wrap">
          <Image 
            src="/images/uploads/11296.webp"
            alt="Груминг питомца в студии ThePetCare"
            width="585"
            height="425"
            loading="lazy"
            format="webp"
            quality={12}
            class="intro-img"
            />
        </AnimatedBlock>
  
        <!-- Текст -->
        <AnimatedBlock animation="fade-left" delay={100} class="intro-text">
          <h2 class="intro-heading">
            Каждая процедура выполнена<br>с любовью и вниманием.
          </h2>
          <p class="intro-desc">
            Мы создаём комфортные условия для животных, чтобы каждая
            процедура была приятной и безопасной.
          </p>
          <a href="/services/" class="intro-link">
            <span class="intro-link-dash">—</span> Наши услуги
          </a>
          <hr class="intro-divider" />
        </AnimatedBlock>
  
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════
       ПРЕИМУЩЕСТВА
  ══════════════════════════════════════════ -->
  <section class="perks section">
    <div class="container">
      <div class="perks-grid">
        {[
          { icon: '🐾', title: 'Любовь к питомцам',    desc: 'Каждая процедура выполнена с заботой и вниманием' },
          { icon: '✂️', title: 'Опытные мастера',       desc: 'Команда профессионалов с многолетним стажем' },
          { icon: '🏠', title: 'Комфортная атмосфера',  desc: 'Создаём спокойную и безопасную обстановку' },
          { icon: '📅', title: 'Онлайн-запись',         desc: 'Удобная запись в любое время через сайт' },
        ].map((perk, i) => (
          <AnimatedBlock animation="fade-up" delay={i * 80} tag="div" class="perk-card">
            <span class="perk-icon">{perk.icon}</span>
            <h3 class="perk-title">{perk.title}</h3>
            <p class="perk-desc">{perk.desc}</p>
          </AnimatedBlock>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════
       УСЛУГИ
  ══════════════════════════════════════════ -->
  <section class="services-section section" id="services">
    <div class="container">
      <AnimatedBlock animation="fade-up">
        <p class="section-eyebrow">Что мы делаем</p>
        <h2 class="section-title">Наши услуги</h2>
      </AnimatedBlock>

      <!-- Табы: Собаки / Кошки -->
      <div class="services-tabs" role="tablist">
        <button class="tab-btn tab-btn--active" data-tab="dogs" role="tab" aria-selected="true">
          🐶 Для собак
        </button>
        <button class="tab-btn" data-tab="cats" role="tab" aria-selected="false">
          🐱 Для кошек
        </button>
      </div>

      <!-- Сетка: Собаки -->
      <div class="services-grid" id="tab-dogs">
        {dogServices.map((s, i) => (
          <AnimatedBlock animation="fade-up" delay={i * 60} tag="div">
            <a href={`/services/${s.slug}/`} class="service-card">
              <div class="service-card-img-wrap">
                {s.image
                  ? <Image src={s.image} alt={s.title} width="400" height="280" loading="lazy" format="webp" quality={12} />
                  : <div class="service-card-img-placeholder"></div>
                }
                {s.price && <span class="price-badge">{s.price}</span>}
              </div>
              <div class="service-card-body">
                <h3 class="service-card-title">{s.title}</h3>
              </div>
            </a>
          </AnimatedBlock>
        ))}
      </div>

      <!-- Сетка: Кошки (скрыта) -->
      <div class="services-grid" id="tab-cats" hidden>
        {catServices.map((s, i) => (
          <AnimatedBlock animation="fade-up" delay={i * 60} tag="div">
            <a href={`/services/${s.slug}/`} class="service-card">
              <div class="service-card-img-wrap">
                {s.image
                  ? <img src={s.image} alt={s.title} width="400" height="280" loading="lazy" />
                  : <div class="service-card-img-placeholder"></div>
                }
                {s.price && <span class="price-badge">{s.price}</span>}
              </div>
              <div class="service-card-body">
                <h3 class="service-card-title">{s.title}</h3>
              </div>
            </a>
          </AnimatedBlock>
        ))}
      </div>

      <AnimatedBlock animation="fade-up" delay={200}>
        <div class="services-cta">
          <a href="/services/" class="btn btn-primary">Все услуги</a>
        </div>
      </AnimatedBlock>
    </div>
  </section>

  <!-- ══════════════════════════════════════════
       О СТУДИИ
  ══════════════════════════════════════════ -->
  <section class="about-section section">
    <div class="container">
      <div class="about-grid">
        <AnimatedBlock animation="fade-right" class="about-text">
          <p class="section-eyebrow">О нас</p>
          <h2 class="section-title">Студия заботливого груминга</h2>
          <p class="about-desc">
            Приглашаем в груминг-салон Калининграда с премиум-услугами для ваших четвероногих
            друзей! Мы больше чем просто зоосалон&nbsp;— мы относимся к каждому питомцу с любовью.
            Гарантируем безопасный сервис и индивидуальный подход!
          </p>
          <div class="about-stats">
            <div class="stat">
              <span class="stat-num">7+</span>
              <span class="stat-label">лет опыта</span>
            </div>
            <div class="stat">
              <span class="stat-num">200+</span>
              <span class="stat-label">довольных клиентов</span>
            </div>
            <div class="stat">
              <span class="stat-num">5</span>
              <span class="stat-label">профессиональных мастеров</span>
            </div>
          </div>
          <a href="/about/" class="btn btn-primary">Подробнее о студии</a>
        </AnimatedBlock>
        <AnimatedBlock animation="fade-left" class="about-image-wrap">
          <img
            src="/images/uploads/11293.webp"
            alt="Студия заботливого груминга — интерьер"
            width="600"
            height="750"
            loading="lazy"
            class="about-img"
          />
        </AnimatedBlock>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════
       МАСТЕРА
  ══════════════════════════════════════════ -->
  <section class="masters-section section">
    <div class="container">
      <AnimatedBlock animation="fade-up">
        <p class="section-eyebrow">Команда</p>
        <h2 class="section-title">Наши профессиональные мастера</h2>
      </AnimatedBlock>
      <div class="masters-grid">
        {masters.map((m, i) => (
          <AnimatedBlock animation="fade-up" delay={i * 80} tag="div" class="master-card">
            <div class="master-photo-wrap">
              {m.img
                ? <img src={m.img} alt={m.name} width="240" height="280" loading="lazy" />
                : <div class="master-photo-placeholder"></div>
              }
            </div>
            <div class="master-info">
              <h3 class="master-name">{m.name}</h3>
              <p class="master-role">{m.role}</p>
              <p class="master-exp">{getExperience(m.expFrom)}</p>
            </div>
          </AnimatedBlock>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════
       ГАЛЕРЕЯ РАБОТ
  ══════════════════════════════════════════ -->
  <section class="gallery-section section">
    <div class="container">
      <AnimatedBlock animation="fade-up">
        <p class="section-eyebrow">Наши работы</p>
        <h2 class="section-title">Галерея работ</h2>
      </AnimatedBlock>
    </div>
    <div class="gallery-track-wrap">
      <div class="gallery-track" id="gallery-track">
        {gallery.map((src, i) => (
          <div class="gallery-slide">
            <a
              class="gallery-slide-link"
              href={src}
              data-fancybox="gallery-works"
              data-caption={`Работа мастеров ThePetCare — фото ${i + 1}`}
            >
              <img src={src} alt={`Работа мастеров ThePetCare ${i + 1}`} width="360" height="480" loading="lazy" />
            </a>
          </div>
        ))}
      </div>
      <button class="gallery-btn gallery-btn--prev" id="gallery-prev" aria-label="Назад">&#8592;</button>
      <button class="gallery-btn gallery-btn--next" id="gallery-next" aria-label="Вперёд">&#8594;</button>
    </div>
  </section>

  <!-- ══════════════════════════════════════════
       КОНТАКТЫ
  ══════════════════════════════════════════ -->
  <section class="contacts-section section">
    <div class="container">
      <AnimatedBlock animation="fade-up">
        <p class="section-eyebrow">Как нас найти</p>
        <h2 class="section-title">Контакты</h2>
      </AnimatedBlock>
      <div class="contacts-grid">
        <!-- Яндекс Карта (lazy) -->
        <AnimatedBlock animation="fade-right" class="contacts-map-wrap">
          <div class="map-container">
            <iframe
              data-src="https://yandex.ru/map-widget/v1/?ll=20.500965%2C54.718210&z=17&pt=20.500965%2C54.718210%2Cpm2rdm&text=%D0%9A%D0%B0%D0%BB%D0%B8%D0%BD%D0%B8%D0%BD%D0%B3%D1%80%D0%B0%D0%B4%2C%20%D1%83%D0%BB.%20%D0%98%D0%B2%D0%B0%D0%BD%D0%B0%20%D0%A1%D1%83%D1%81%D0%B0%D0%BD%D0%B8%D0%BD%D0%B0%2C%2024"
              class="yandex-map"
              width="100%"
              height="400"
              frameborder="0"
              allowfullscreen
              title="Карта — ThePetCare на ул. Ивана Сусанина, 24"
            ></iframe>
            <div class="map-placeholder" aria-hidden="true">
              <span>🗺️ Карта загружается...</span>
            </div>
          </div>
        </AnimatedBlock>

        <!-- Инфо + отзывы -->
        <AnimatedBlock animation="fade-left" class="contacts-info">
          <div class="contacts-details">
            <div class="contacts-detail-row">
              <span class="detail-icon">📍</span>
              <div>
                <p class="detail-label">Адрес</p>
                <p class="detail-value">г. Калининград, ул. Ивана Сусанина, д. 24</p>
              </div>
            </div>
            <div class="contacts-detail-row">
              <span class="detail-icon">📞</span>
              <div>
                <p class="detail-label">Телефон</p>
                <a href={`tel:${site.contacts.phoneRaw}`} class="detail-value detail-link">
                  {site.contacts.phone}
                </a>
              </div>
            </div>
            <div class="contacts-detail-row">
              <span class="detail-icon">🕐</span>
              <div>
                <p class="detail-label">Режим работы</p>
                <p class="detail-value">Ежедневно, 9:00–19:00</p>
              </div>
            </div>
          </div>

          <!-- Рейтинг Яндекс -->
          <div class="yandex-rating-card">
            <div class="rating-header">
              <span class="rating-source">Яндекс Карты</span>
              <a
                href="https://yandex.ru/maps/org/studiya_zabotlivogo_gruminga/48464456070/"
                target="_blank"
                rel="noopener noreferrer"
                class="rating-link"
              >Читать отзывы →</a>
            </div>
            <div class="rating-row">
              <span class="rating-score">5,0</span>
              <span class="rating-stars">★★★★★</span>
            </div>
            <p class="rating-meta">63 отзыва · 80 оценок</p>
            <div class="review-item">
              <div class="review-author-row">
                <span class="review-author">Анастасия Литвиненко</span>
                <span class="review-stars">★★★★★</span>
              </div>
              <p class="review-text">
                Это был наш первый груминг, и я счастлива, что выбор пал на этот салон!
                Привезли кошечку на вычес, мы обе так боялись, когда я увидела собак за шторкой…
              </p>
            </div>
          </div>
        </AnimatedBlock>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════
       CTA BANNER
  ══════════════════════════════════════════ -->
  <section class="cta-banner">
    <div class="container">
      <AnimatedBlock animation="fade-up" class="cta-inner">
        <div class="cta-grid">
          <div class="cta-content">
            <h2 class="cta-title">Подобрать подходящую услугу?</h2>
            <p class="cta-sub">Оставьте заявку — мы перезвоним и ответим на все вопросы.</p>
          </div>
          <div class="cta-actions">
            <button class="btn btn-primary" data-open-callback>
              Заказать обратный звонок
            </button>
          </div>
        </div>
        <div class="cta-actions">
        </div>
      </AnimatedBlock>
    </div>
  </section>

</BaseLayout>

<style>
  /* ── Hero ───────────────────────────────────── */
  .hero {
    position:   relative;
    min-height: 92vh;
    display:    flex;
    align-items: center;
    overflow:   hidden;
    color:      #fff;
  }

  .hero-bg {
    position:   absolute;
    inset:      0;
    background: url('/images/uploads/hero-bg.webp') center/cover no-repeat,
                linear-gradient(135deg, #2a1810 0%, #3d2315 50%, #1a1208 100%);
    z-index:    0;
  }
  .hero-bg::after {
    content:    '';
    position:   absolute;
    inset:      0;
    background: linear-gradient(
      to right,
      rgba(17, 10, 6, 0.72) 0%,
      rgba(17, 10, 6, 0.55) 50%,
      rgba(17, 10, 6, 0.20) 100%
    );
  }

  .hero-content {
    position:  relative;
    z-index:   1;
    padding-block: var(--spacing-96);
    max-width: 1000px;
  }

  .hero-eyebrow {
    font-family:    var(--font-sohne);
    font-size:      13px;
    font-weight:    500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color:          rgba(251, 225, 209, 0.85);
    margin-bottom:  var(--spacing-16);
  }

  .hero-title {
    font-family:    var(--font-signifier);
    font-size:      clamp(28px, 3vw, 50px);
    font-weight:    400;
    line-height:    1.1;
    letter-spacing: -0.02em;
    color:          #fff;
    margin-bottom:  var(--spacing-24);
  }

  .hero-sub {
    font-family:    var(--font-sohne);
    font-size:      18px;
    font-weight:    400;
    line-height:    1.65;
    color:          rgba(255, 255, 255, 0.82);
    max-width:      500px;
    margin-bottom:  var(--spacing-40);
  }

  .hero-actions {
    display:     flex;
    gap:         var(--spacing-12);
    flex-wrap:   wrap;
    margin-bottom: var(--spacing-32);
  }

  .btn-hero {
    background:    var(--color-warm-mist);
    color:         var(--color-terracotta);
    border:        none;
    padding:       14px 32px;
    border-radius: 9999px;
    font-family:   var(--font-sohne);
    font-size:     15px;
    font-weight:   500;
    cursor:        pointer;
    transition:    background 0.2s ease, transform 0.15s ease;
    text-decoration: none;
    display:       inline-flex;
    align-items:   center;
  }
  .btn-hero:hover { background: #f5d4be; transform: translateY(-1px); }

  .btn-hero-ghost {
    background:    transparent;
    color:         rgba(255,255,255,0.9);
    border:        1.5px solid rgba(255,255,255,0.4);
    padding:       14px 28px;
    border-radius: 9999px;
    font-family:   var(--font-sohne);
    font-size:     15px;
    font-weight:   450;
    cursor:        pointer;
    transition:    border-color 0.2s ease, color 0.2s ease;
    text-decoration: none;
    display:       inline-flex;
    align-items:   center;
  }
  .btn-hero-ghost:hover {
    border-color:  rgba(255,255,255,0.7);
    color:         #fff;
  }

  .hero-address {
    font-size:  14px;
    color:      rgba(255,255,255,0.6);
    font-family: var(--font-sohne);
  }

  /* ── Intro-блок ────────────────────────────── */
  .intro-block {
    background: var(--color-canvas);
    overflow:   hidden;
  }

  .intro-grid {
    display: grid;
    grid-template-columns: 55fr 45fr;
    padding: var(--spacing-80);
    gap: var(--spacing-80);
    align-items: center;
    min-height: 520px;
  }

  .intro-img-wrap {
    overflow: hidden;
    height:   100%;
  }

  .intro-img {
    width:      585px;
    height:     425px;
    object-fit: cover;
    display:    block;
    transition: transform 0.6s ease;
  }
  .intro-img:hover { transform: scale(1.02); }

  .intro-text {
    display:         flex;
    flex-direction:  column;
    justify-content: center;
    padding:         var(--spacing-80) var(--spacing-80) var(--spacing-64);
    gap:             var(--spacing-24);
  }

  .intro-heading {
    font-family:    var(--font-sohne);
    font-size:      clamp(22px, 2.5vw, 30px);
    font-weight:    700;
    line-height:    1.2;
    letter-spacing: -0.02em;
    color:          var(--color-ink);
  }

  .intro-desc {
    font-family: var(--font-sohne);
    font-size:   17px;
    line-height: 1.65;
    color:       var(--color-muted-stone);
    max-width:   420px;
  }

  .intro-link {
    display:     inline-flex;
    align-items: center;
    gap:         var(--spacing-12);
