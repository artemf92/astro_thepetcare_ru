# Вставить в конфиг уже существующего фронтового nginx (слушает 80/443 на хосте),
# после того как контейнер thepetcare-nginx добавлен в ту же Docker-сеть.


# ── Карта Upgrade (может уже есть в вашем конфиге — не дублировать)

# map $http_upgrade $connection_upgrade {
#     default upgrade;
#     ''      close;
# }


upstream thepetcare_nginx {
    server thepetcare-nginx:80;
    keepalive 32;
}


# Если TLS терминируете здесь же — добавьте server на 443;
# ниже упрощённый пример только reverse proxy.


